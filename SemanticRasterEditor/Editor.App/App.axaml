<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Editor.App.App"
             RequestedThemeVariant="Dark">

    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="avares://Editor.App/Themes/Colors.axaml"/>
        <StyleInclude Source="avares://Editor.App/Themes/Typography.axaml"/>
        <StyleInclude Source="avares://Editor.App/Themes/Controls.axaml"/>
    </Application.Styles>
</Application>
