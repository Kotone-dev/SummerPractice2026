<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Editor.App.AiChatPanel"
             Width="280" Background="#2C2F34"
             FontFamily="Segoe UI">

    <DockPanel>
        <!-- Header -->
        <Border DockPanel.Dock="Top" BorderBrush="#4A4A4A" BorderThickness="0,0,0,1" Padding="8,6">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Text="ИИ Ассистент" FontSize="11" FontWeight="SemiBold"
                           Foreground="#888888" Grid.Column="0" VerticalAlignment="Center" />
                <StackPanel Orientation="Horizontal" Spacing="4" Grid.Column="1">
                    <Button ToolTip.Tip="Свернуть" Padding="4" Background="Transparent">
                        <TextBlock Text="—" Foreground="#888888" FontSize="12" />
                    </Button>
                    <Button ToolTip.Tip="Закрыть" Padding="4" Background="Transparent">
                        <TextBlock Text="✕" Foreground="#888888" FontSize="12" />
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Command input section -->
        <Border x:Name="CommandBorder" DockPanel.Dock="Bottom"
                BorderBrush="#4A4A4A" BorderThickness="0,0,0,1" Padding="8,6">
            <StackPanel Spacing="4">
                <TextBlock Text="Команды" FontSize="10" FontWeight="SemiBold"
                           Foreground="#888888" />
                <Grid ColumnDefinitions="*,Auto">
                    <TextBox x:Name="CommandInput"
                             Grid.Column="0"
                             PlaceholderText="яркость 50, удалить, найти дерево..."
                             Background="#3A3F47"
                             Foreground="#CCCCCC"
                             BorderThickness="0"
                             Height="26"
                             VerticalContentAlignment="Center"
                             Margin="0,0,6,0" />
                    <Button x:Name="BtnExecute" Grid.Column="1"
                            ToolTip.Tip="Выполнить команду"
                            Padding="6,3" Background="#3A3F47"
                            CornerRadius="3">
                        <TextBlock Text="▶" FontSize="11" Foreground="#5BA4CF" />
                    </Button>
                </Grid>
                <TextBlock Text="Введите &quot;помощь&quot; для списка команд"
                           FontSize="9" Foreground="#666666"
                           TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <!-- Text search section -->
        <Border x:Name="TextSearchBorder" DockPanel.Dock="Bottom"
                BorderBrush="#4A4A4A" BorderThickness="0,0,0,1" Padding="8,6">
            <StackPanel Spacing="4">
                <TextBlock Text="Поиск по тексту" FontSize="10" FontWeight="SemiBold"
                           Foreground="#888888" />
                <Grid ColumnDefinitions="*,Auto">
                    <TextBox x:Name="TextSearchInput"
                             Grid.Column="0"
                             PlaceholderText="Описание объекта..."
                             Background="#3A3F47"
                             Foreground="#CCCCCC"
                             BorderThickness="0"
                             Height="26"
                             VerticalContentAlignment="Center"
                             Margin="0,0,6,0" />
                    <Button x:Name="BtnTextSearch" Grid.Column="1"
                            ToolTip.Tip="Найти объект"
                            Padding="6,3" Background="#3A3F47"
                            CornerRadius="3">
                        <TextBlock Text="Найти" FontSize="11" Foreground="#5BA4CF" />
                    </Button>
                </Grid>
            </StackPanel>
        </Border>

        <!-- Chat messages area -->
        <ScrollViewer x:Name="ChatScroll" DockPanel.Dock="Bottom"
                      VerticalScrollBarVisibility="Auto" MaxHeight="300">
            <StackPanel x:Name="ChatMessages" Spacing="4" Margin="8,8,8,4">
                <!-- TODO: реализовать отображение сообщений AI-чата -->
                <Border Background="#3A3F47" CornerRadius="4" Padding="8,6">
                    <TextBlock Text="Привет! Я ваш AI-ассистент.&#x0a;Опишите, что вы хотите сделать с изображением."
                               Foreground="#CCCCCC" FontSize="11" TextWrapping="Wrap" />
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Progress indicator (hidden by default) -->
        <Border x:Name="ProgressBorder" DockPanel.Dock="Bottom"
                Background="#2C2F34" BorderBrush="#4A4A4A" BorderThickness="0,0,0,1"
                Padding="8,6" IsVisible="False">
            <StackPanel Orientation="Horizontal" Spacing="6">
                <TextBlock x:Name="ProgressText" Text="● Анализ..."
                           Foreground="#5BA4CF" FontSize="11" />
            </StackPanel>
        </Border>

        <!-- Input area -->
        <Border DockPanel.Dock="Bottom" BorderBrush="#4A4A4A" BorderThickness="0,1,0,0"
                Padding="8,6">
            <Grid ColumnDefinitions="*,Auto">
                <TextBox x:Name="ChatInput"
                         Grid.Column="0"
                         PlaceholderText="Введите команду..."
                         Background="#3A3F47"
                         Foreground="#CCCCCC"
                         BorderThickness="0"
                         Height="28"
                         VerticalContentAlignment="Center"
                         Margin="0,0,6,0" />
                <Button x:Name="BtnSend" Grid.Column="1"
                        ToolTip.Tip="Отправить"
                        Padding="6,4" Background="Transparent">
                    <Path Data="M2,2 L22,12 L2,22 L5,12 Z"
                          Stroke="#5BA4CF" StrokeThickness="1.5"
                          Width="14" Height="14" Stretch="Uniform" Fill="Transparent" />
                </Button>
            </Grid>
        </Border>
    </DockPanel>

</UserControl>
