<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Editor.App.ToolPalette"
             Width="48" Background="#1B1E22"
             FontFamily="Segoe UI">

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <StackPanel Spacing="0">
            <!-- Move (V) -->
            <Button x:Name="BtnMove" Classes="tool-btn" ToolTip.Tip="Перемещение (V)"
                    Height="40" Padding="4" Background="Transparent">
                <Path Data="M12,2 L12,22 M2,12 L22,12 M12,2 L8,6 M12,2 L16,6 M12,22 L8,18 M12,22 L16,18 M2,12 L6,8 M2,12 L6,16 M22,12 L18,8 M22,12 L18,16"
                      Stroke="#CCCCCC" StrokeThickness="1.5" Width="20" Height="20"
                      Stretch="Uniform" />
            </Button>

            <!-- Selection group -->
            <!-- Rectangular Marquee (M) -->
            <Button x:Name="BtnMarquee" Classes="tool-btn" ToolTip.Tip="Прямоугольное выделение (M)"
                    Height="40" Padding="4" Background="Transparent">
                <Path Data="M3,3 L21,3 L21,21 L3,21 Z"
                      Stroke="#CCCCCC" StrokeThickness="1.5" StrokeDashArray="4,2"
                      Width="20" Height="20" Stretch="Uniform" Fill="Transparent" />
            </Button>

            <!-- Lasso (L) -->
            <Button x:Name="BtnLasso" Classes="tool-btn" ToolTip.Tip="Лассо (L)"
                    Height="40" Padding="4" Background="Transparent">
                <Path Data="M8,20 C4,18 2,14 3,10 C4,6 8,3 12,3 C16,3 20,5 21,9 C22,13 20,16 17,18"
                      Stroke="#CCCCCC" StrokeThickness="1.5" Width="20" Height="20"
                      Stretch="Uniform" Fill="Transparent" />
            </Button>

            <Border Background="#4A4A4A" Height="1" Margin="6,6" />

            <!-- Brush group -->
            <!-- Brush (B) -->
            <Button x:Name="BtnBrush" Classes="tool-btn" ToolTip.Tip="Кисть (B)"
                    Height="40" Padding="4" Background="Transparent">
                <Path Data="M20,2 L8,14 L6,18 L2,22 L6,18 L10,16 L22,4 Z M8,14 L10,16"
                      Stroke="#CCCCCC" StrokeThickness="1.5" Width="20" Height="20"
                      Stretch="Uniform" Fill="Transparent" />
            </Button>

            <!-- Eraser (E) -->
            <Button x:Name="BtnEraser" Classes="tool-btn" ToolTip.Tip="Ластик (E)"
                    Height="40" Padding="4" Background="Transparent">
                <Path Data="M9,22 L2,15 L11,6 L20,15 L13,22 Z M9,22 L13,22 M2,15 L20,15 M11,6 L9,2 L20,15"
                      Stroke="#CCCCCC" StrokeThickness="1.5" Width="20" Height="20"
                      Stretch="Uniform" Fill="Transparent" />
            </Button>

            <Border Background="#4A4A4A" Height="1" Margin="6,6" />

            <!-- Fill group -->
            <!-- Paint Bucket (G) -->
            <Button x:Name="BtnFill" Classes="tool-btn" ToolTip.Tip="Заливка (G)"
                    Height="40" Padding="4" Background="Transparent">
                <Path Data="M5,17 L12,4 L19,17 Z M15,17 C17,19 19,21 19,22 C19,23 17,24 15,22 C13,24 11,23 11,22 C11,21 13,19 15,17 Z"
                      Stroke="#CCCCCC" StrokeThickness="1.5" Width="20" Height="20"
                      Stretch="Uniform" Fill="Transparent" />
            </Button>

            <Border Background="#4A4A4A" Height="1" Margin="6,6" />

            <!-- Text group -->
            <!-- Text (T) -->
            <Button x:Name="BtnText" Classes="tool-btn" ToolTip.Tip="Текст (T)"
                    Height="40" Padding="4" Background="Transparent">
                <Path Data="M5,4 L19,4 M12,4 L12,21 M8,21 L16,21"
                      Stroke="#CCCCCC" StrokeThickness="1.5" Width="20" Height="20"
                      Stretch="Uniform" />
            </Button>

            <!-- Eyedropper (I) -->
            <Button x:Name="BtnEyedropper" Classes="tool-btn" ToolTip.Tip="Пипетка (I)"
                    Height="40" Padding="4" Background="Transparent">
                <Path Data="M18,2 L22,6 L10,18 L6,18 L6,14 Z M15,5 L19,9"
                      Stroke="#CCCCCC" StrokeThickness="1.5" Width="20" Height="20"
                      Stretch="Uniform" Fill="Transparent" />
            </Button>

            <Border Background="#4A4A4A" Height="1" Margin="6,6" />

            <!-- Crop group -->
            <!-- Crop (C) -->
            <Button x:Name="BtnCrop" Classes="tool-btn" ToolTip.Tip="Кадрирование (C)"
                    Height="40" Padding="4" Background="Transparent">
                <Path Data="M6,2 L6,18 L22,18 M2,6 L18,6 L18,22"
                      Stroke="#CCCCCC" StrokeThickness="1.5" Width="20" Height="20"
                      Stretch="Uniform" Fill="Transparent" />
            </Button>

            <Border Background="#4A4A4A" Height="1" Margin="6,6" />

            <!-- Navigation group -->
            <!-- Hand (H) -->
            <Button x:Name="BtnHand" Classes="tool-btn" ToolTip.Tip="Рука (H)"
                    Height="40" Padding="4" Background="Transparent">
                <Path Data="M12,2 L12,14 M8,6 L8,12 M16,8 L16,14 M4,10 L4,14 C4,18 8,22 12,22 C16,22 20,18 20,14 L20,10"
                      Stroke="#CCCCCC" StrokeThickness="1.5" Width="20" Height="20"
                      Stretch="Uniform" Fill="Transparent" />
            </Button>

            <!-- Zoom (Z) -->
            <Button x:Name="BtnZoom" Classes="tool-btn" ToolTip.Tip="Масштаб (Z)"
                    Height="40" Padding="4" Background="Transparent">
                <Path Data="M10,10 L16,16 M10,10 C6,10 3,13 3,17 C3,21 6,24 10,24 C14,24 17,21 17,17 C17,13 14,10 10,10 Z M21,21 L24,24"
                      Stroke="#CCCCCC" StrokeThickness="1.5" Width="20" Height="20"
                      Stretch="Uniform" Fill="Transparent" />
            </Button>

            <Border Background="#4A4A4A" Height="1" Margin="6,6" />

            <!-- SAM Smart Select -->
            <Button x:Name="BtnSmartSelect" Classes="tool-btn" ToolTip.Tip="Умное выделение (SAM)"
                    Height="40" Padding="4" Background="Transparent">
                <Path Data="M12,2 C7,2 3,6 3,11 C3,16 7,20 12,20 C14,20 16,19 18,18 L22,22 L18,18 C20,16 21,13 21,11 C21,6 17,2 12,2 Z M12,8 C13,8 14,9 14,10 C14,11 13,12 12,12 C11,12 10,11 10,10 C10,9 11,8 12,8 Z"
                      Stroke="#5BA4CF" StrokeThickness="1.5" Width="20" Height="20"
                      Stretch="Uniform" Fill="Transparent" />
            </Button>
        </StackPanel>
    </ScrollViewer>

    <UserControl.Styles>
        <Style Selector="Button.tool-btn:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#3A3F47" />
        </Style>
        <Style Selector="Button.tool-btn.selected /template/ ContentPresenter">
            <Setter Property="Background" Value="#3A3F47" />
        </Style>
        <Style Selector="Button.tool-btn.selected">
            <Setter Property="BorderBrush" Value="#5BA4CF" />
            <Setter Property="BorderThickness" Value="2,0,0,0" />
            <Setter Property="Padding" Value="4" />
        </Style>
    </UserControl.Styles>

</UserControl>
