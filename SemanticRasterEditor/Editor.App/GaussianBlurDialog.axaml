<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Editor.App.GaussianBlurDialog"
        Title="Размытие по Гауссу"
        Width="520" Height="300"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        Background="{StaticResource WindowBackgroundBrush}">

    <DockPanel Margin="16">
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Spacing="8" Margin="0,12,0,0">
            <Button x:Name="BtnCancel" Content="Отмена" Width="90" Height="28" />
            <Button x:Name="BtnApply" Content="Применить" Width="90" Height="28" />
        </StackPanel>

        <Grid ColumnDefinitions="*,220">
            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                <TextBlock Text="Радиус размытия:"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           FontSize="{StaticResource FontSizeBody}" Margin="0,0,0,8" />
                <Slider x:Name="RadiusSlider" Minimum="1" Maximum="20" Value="3" Width="250" />
                <TextBlock x:Name="RadiusText" Text="3"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           HorizontalAlignment="Center" Margin="0,4,0,0" />
            </StackPanel>

            <Border Grid.Column="1"
                    BorderBrush="{StaticResource BorderBrushCustom}"
                    BorderThickness="1">
                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Auto"
                              Background="Transparent">
                    <Image x:Name="PreviewImage" Stretch="None" />
                </ScrollViewer>
            </Border>
        </Grid>
    </DockPanel>
</Window>
