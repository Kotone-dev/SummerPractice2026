<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Editor.App.GaussianBlurDialog"
        Title="Размытие по Гауссу"
        Width="300" Height="180"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        Background="{StaticResource WindowBackgroundBrush}">

    <StackPanel Margin="20" Spacing="12">
        <TextBlock Text="Радиус размытия:" Foreground="{StaticResource TextPrimaryBrush}"
                   FontSize="{StaticResource FontSizeBody}" />
        <Slider x:Name="RadiusSlider" Minimum="1" Maximum="20" Value="3"
                Width="250" />
        <TextBlock x:Name="RadiusText" Text="3"
                   Foreground="{StaticResource TextSecondaryBrush}"
                   HorizontalAlignment="Center" />

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
            <Button Content="Отмена" Width="90" Height="28" x:Name="BtnCancel"
                    Background="{StaticResource PanelBackgroundBrush}"
                    Foreground="{StaticResource TextPrimaryBrush}" />
            <Button Content="Применить" Width="90" Height="28" x:Name="BtnApply"
                    Background="{StaticResource AccentBrush}"
                    Foreground="White" />
        </StackPanel>
    </StackPanel>
</Window>
