<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Editor.App"
             x:Class="Editor.App.LayerPanel"
             Width="300"
             Background="{StaticResource PanelBackgroundBrush}">

    <DockPanel>
        <!-- Tabs: Слои | Каналы -->
        <TabControl x:Name="LayerTabs"
                    Background="Transparent" BorderThickness="0"
                    FontSize="{StaticResource FontSizeBody}" Padding="0">
            <TabItem x:Name="TabLayers" Header="Слои">
                <DockPanel>
                    <!-- Bottom: layer buttons -->
                    <Border DockPanel.Dock="Bottom"
                            BorderBrush="{StaticResource BorderBrushCustom}"
                            BorderThickness="0,1,0,0"
                            Padding="12,4">
                        <StackPanel Orientation="Horizontal" Spacing="4"
                                    HorizontalAlignment="Right">
                            <Button x:Name="BtnAdd" ToolTip.Tip="Добавить слой"
                                    Padding="6,2" Height="24"
                                    FontSize="{StaticResource FontSizeBody}">
                                <TextBlock Text="+" FontSize="14"
                                           Foreground="{StaticResource TextPrimaryBrush}" />
                            </Button>
                            <Button x:Name="BtnRemove" ToolTip.Tip="Удалить слой"
                                    Padding="6,2" Height="24"
                                    FontSize="{StaticResource FontSizeBody}">
                                <TextBlock Text="−" FontSize="14"
                                           Foreground="{StaticResource TextPrimaryBrush}" />
                            </Button>
                            <Button x:Name="BtnUp" ToolTip.Tip="Переместить вверх"
                                    Padding="6,2" Height="24"
                                    FontSize="{StaticResource FontSizeBody}">
                                <TextBlock Text="▲" FontSize="10"
                                           Foreground="{StaticResource TextPrimaryBrush}" />
                            </Button>
                            <Button x:Name="BtnDown" ToolTip.Tip="Переместить вниз"
                                    Padding="6,2" Height="24"
                                    FontSize="{StaticResource FontSizeBody}">
                                <TextBlock Text="▼" FontSize="10"
                                           Foreground="{StaticResource TextPrimaryBrush}" />
                            </Button>
                        </StackPanel>
                    </Border>

                    <!-- Layer list fills remaining space -->
                    <ListBox x:Name="LayerList"
                             Background="Transparent"
                             BorderThickness="0"
                             Foreground="{StaticResource TextPrimaryBrush}"
                             FontSize="{StaticResource FontSizeBody}"
                             SelectionMode="Single" />
                </DockPanel>
            </TabItem>
            <TabItem x:Name="TabChannels" Header="Каналы">
                <local:ChannelsPanel x:Name="ChannelsPanel" />
            </TabItem>
        </TabControl>
    </DockPanel>

</UserControl>
