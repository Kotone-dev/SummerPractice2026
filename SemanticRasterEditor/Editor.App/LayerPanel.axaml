<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Editor.App"
             x:Class="Editor.App.LayerPanel"
             Width="260" Background="#2C2F34">

    <DockPanel>
        <!-- Tabs: Слои | Каналы -->
        <TabControl x:Name="LayerTabs"
                    Background="Transparent" BorderThickness="0"
                    FontSize="11" Padding="0">
            <TabItem x:Name="TabLayers" Header="Слои">
                <DockPanel>
                    <!-- Bottom: opacity, fill, buttons -->
                    <Border DockPanel.Dock="Bottom" BorderBrush="#4A4A4A"
                            BorderThickness="0,1,0,0" Padding="8,8">
                        <StackPanel Spacing="4">
                            <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto">
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Непрозрачность:"
                                           Foreground="#888888" FontSize="11"
                                           VerticalAlignment="Center" Margin="0,0,6,0" />
                                <Slider Grid.Row="0" Grid.Column="1" x:Name="LayerOpacitySlider"
                                        Minimum="0" Maximum="100" Value="100"
                                        VerticalAlignment="Center" />

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Заливка:"
                                           Foreground="#888888" FontSize="11"
                                           VerticalAlignment="Center" Margin="0,0,6,0" />
                                <Grid Grid.Row="1" Grid.Column="1" ColumnDefinitions="*,Auto">
                                    <Slider x:Name="LayerFillSlider" Minimum="0" Maximum="100"
                                            Value="100" VerticalAlignment="Center" />
                                    <Button Grid.Column="1"
                                            ToolTip.Tip="Заблокировать прозрачность"
                                            Padding="4" Background="Transparent"
                                            HorizontalAlignment="Right">
                                        <Path Data="M8,4 L16,4 L16,20 L8,20 Z M10,4 L10,2 C10,1 11,0 12,0 C13,0 14,1 14,2 L14,4"
                                              Stroke="#888888" StrokeThickness="1.5"
                                              Width="10" Height="12"
                                              Stretch="Uniform" Fill="Transparent" />
                                    </Button>
                                </Grid>
                            </Grid>

                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <Button x:Name="BtnAdd" ToolTip.Tip="Добавить слой"
                                        Padding="6,2" Background="#3A3F47" Foreground="#CCCCCC">
                                    <TextBlock Text="+" FontSize="12" />
                                </Button>
                                <Button x:Name="BtnRemove" ToolTip.Tip="Удалить слой"
                                        Padding="6,2" Background="#3A3F47" Foreground="#CCCCCC">
                                    <TextBlock Text="−" FontSize="12" />
                                </Button>
                                <Button x:Name="BtnUp" ToolTip.Tip="Переместить вверх"
                                        Padding="6,2" Background="#3A3F47" Foreground="#CCCCCC">
                                    <TextBlock Text="▲" FontSize="10" />
                                </Button>
                                <Button x:Name="BtnDown" ToolTip.Tip="Переместить вниз"
                                        Padding="6,2" Background="#3A3F47" Foreground="#CCCCCC">
                                    <TextBlock Text="▼" FontSize="10" />
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Layer list fills remaining space -->
                    <ListBox x:Name="LayerList"
                             Background="Transparent"
                             BorderThickness="0"
                             Foreground="#CCCCCC"
                             SelectionMode="Single" />
                </DockPanel>
            </TabItem>
            <TabItem x:Name="TabChannels" Header="Каналы">
                <local:ChannelsPanel x:Name="ChannelsPanel" />
            </TabItem>
        </TabControl>
    </DockPanel>

</UserControl>
