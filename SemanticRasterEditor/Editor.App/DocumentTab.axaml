<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Editor.App.DocumentTab"
             Height="30"
             Background="{StaticResource ToolbarBackgroundBrush}"
             FontFamily="Segoe UI">

    <Border BorderBrush="{StaticResource BorderBrushCustom}"
            BorderThickness="0,0,0,1"
            Padding="12,6">
        <StackPanel Orientation="Horizontal" Spacing="8">
            <TextBlock x:Name="FileNameText"
                       Text="Без имени"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       FontSize="{StaticResource FontSizeSmall}"
                       VerticalAlignment="Center" />
            <TextBlock Text="·"
                       Foreground="{StaticResource TextDisabledBrush}"
                       FontSize="{StaticResource FontSizeSmall}"
                       VerticalAlignment="Center" />
            <TextBlock x:Name="ZoomText"
                       Text="100%"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       FontSize="{StaticResource FontSizeSmall}"
                       VerticalAlignment="Center" />
            <TextBlock Text="·"
                       Foreground="{StaticResource TextDisabledBrush}"
                       FontSize="{StaticResource FontSizeSmall}"
                       VerticalAlignment="Center" />
            <TextBlock x:Name="ColorModeText"
                       Text="RGB/8"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       FontSize="{StaticResource FontSizeSmall}"
                       VerticalAlignment="Center" />
            <TextBlock x:Name="ModifiedIndicator"
                       Text="●"
                       Foreground="{StaticResource AccentBrush}"
                       FontSize="8"
                       VerticalAlignment="Center"
                       IsVisible="False" />
        </StackPanel>
    </Border>

</UserControl>
