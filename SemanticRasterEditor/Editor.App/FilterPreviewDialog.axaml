<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Editor.App.FilterPreviewDialog"
        Title="Предпросмотр фильтра"
        Width="500" Height="380"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        Background="{StaticResource WindowBackgroundBrush}"
        FontFamily="Segoe UI">

    <DockPanel Margin="16">
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Spacing="8" Margin="0,16,0,0">
            <Button x:Name="BtnCancel" Content="Отмена" Width="100" Height="28"
                    FontSize="{StaticResource FontSizeBody}" />
            <Button x:Name="BtnApply" Content="Применить" Width="100" Height="28"
                    FontSize="{StaticResource FontSizeBody}" />
        </StackPanel>

        <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,*">
            <TextBlock Grid.Row="0" Grid.Column="0" Text="До:"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       FontSize="{StaticResource FontSizeBody}" Margin="0,0,0,6" />
            <TextBlock Grid.Row="0" Grid.Column="1" Text="После:"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       FontSize="{StaticResource FontSizeBody}" Margin="0,0,0,6" />

            <Border Grid.Row="1" Grid.Column="0"
                    BorderBrush="{StaticResource BorderBrushCustom}"
                    BorderThickness="1" Margin="0,0,6,0">
                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Auto">
                    <Image x:Name="ImageBefore" Stretch="None" />
                </ScrollViewer>
            </Border>
            <Border Grid.Row="1" Grid.Column="1"
                    BorderBrush="{StaticResource BorderBrushCustom}"
                    BorderThickness="1" Margin="6,0,0,0">
                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Auto">
                    <Image x:Name="ImageAfter" Stretch="None" />
                </ScrollViewer>
            </Border>
        </Grid>
    </DockPanel>
</Window>
