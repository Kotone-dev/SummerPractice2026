<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Editor.App.FilterDialog"
        Title="Яркость и контраст"
        Width="400" Height="220"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        Background="#1B1E22"
        FontFamily="Segoe UI"
        FontSize="11">

    <Grid Margin="16" RowDefinitions="Auto,Auto,Auto,*">

        <Grid Grid.Row="0" ColumnDefinitions="100,*" Margin="0,0,0,12">
            <TextBlock Text="Яркость:" Foreground="#CCCCCC" VerticalAlignment="Center" />
            <Slider Grid.Column="1" x:Name="BrightnessSlider"
                    Minimum="-255" Maximum="255" Value="0"
                    TickFrequency="1" IsSnapToTickEnabled="True" />
        </Grid>

        <Grid Grid.Row="1" ColumnDefinitions="100,*" Margin="0,0,0,12">
            <TextBlock Text="Контраст:" Foreground="#CCCCCC" VerticalAlignment="Center" />
            <Slider Grid.Column="1" x:Name="ContrastSlider"
                    Minimum="-100" Maximum="100" Value="0"
                    TickFrequency="1" IsSnapToTickEnabled="True" />
        </Grid>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Отмена" Width="100" Margin="0,0,8,0"
                    Click="OnCancelClick" />
            <Button Content="Применить" Width="100"
                    Click="OnApplyClick" />
        </StackPanel>
    </Grid>

</Window>
