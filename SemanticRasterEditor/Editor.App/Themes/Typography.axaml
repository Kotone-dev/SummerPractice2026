<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Styles.Resources>
        <x:Double x:Key="FontSizeMicro">10</x:Double>
        <x:Double x:Key="FontSizeSmall">11</x:Double>
        <x:Double x:Key="FontSizeBody">12</x:Double>
        <x:Double x:Key="FontSizeMenu">13</x:Double>
        <x:Double x:Key="FontSizePanelHeader">13</x:Double>
        <x:Double x:Key="FontSizeTitle">14</x:Double>

        <x:Double x:Key="ControlHeightSmall">24</x:Double>
        <x:Double x:Key="ControlHeightMedium">28</x:Double>
        <x:Double x:Key="ControlHeightLarge">32</x:Double>

        <x:Double x:Key="SpacingXSmall">2</x:Double>
        <x:Double x:Key="SpacingSmall">4</x:Double>
        <x:Double x:Key="SpacingMedium">8</x:Double>
        <x:Double x:Key="SpacingLarge">12</x:Double>
        <x:Double x:Key="SpacingXLarge">16</x:Double>

        <CornerRadius x:Key="CornerRadiusSmall">2</CornerRadius>
        <CornerRadius x:Key="CornerRadiusMedium">3</CornerRadius>
        <CornerRadius x:Key="CornerRadiusLarge">4</CornerRadius>
    </Styles.Resources>

</Styles>
